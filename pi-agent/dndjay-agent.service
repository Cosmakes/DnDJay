[Unit]
Description=DnDJay WebSocket display agent
After=mpv-dndjay.service
Requires=mpv-dndjay.service

[Service]
ExecStart=/usr/bin/python3 /opt/dndjay/agent.py \
  --host 0.0.0.0 --port 8765 \
  --cache-dir /var/lib/dndjay/cache \
  --mpv-ipc /tmp/mpv-dndjay.sock
Restart=always
RestartSec=2
User=pi
Group=video

[Install]
WantedBy=multi-user.target
